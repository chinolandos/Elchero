# ─── Chero — Variables de entorno ───
# Copiá este archivo a `.env.local` y pegá tus keys reales.
# NUNCA subas .env.local a git (ya está en .gitignore).

# ─── OpenAI (Whisper transcripción + TTS) ───
OPENAI_API_KEY=sk-proj-...

# ─── Anthropic (Claude Sonnet 4.6 para apuntes + Haiku para auto-detección) ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://iiqomtnbmtxagzbjsvil.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ─── Configuración de uso (límite global del MVP) ───
MAX_TOTAL_USES=50
MAX_USES_PER_USER=5

# ─── Cron secret (genera uno aleatorio con `openssl rand -hex 32`) ───
# Protege /api/cron/* para que solo Vercel Cron pueda llamarlos.
CRON_SECRET=cambia-esto-por-un-valor-aleatorio-largo

# ─── Vercel (auto-injectado en producción, solo necesario localmente si querés) ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
